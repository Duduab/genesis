# Genesis API — default origin is staging Cloud Run (see src/config/genesisEnv.ts).
# Optional: override origin (e.g. production API).
# VITE_GENESIS_API_BASE_URL=https://genesis-api-242231160010.me-west1.run.app
# Bearer token (no "Bearer " prefix): dev-admin-test | dev-operator-user1 | dev-entrepreneur-user1
# In `npm run dev`, entrepreneur token is used when this is unset. Production builds need a real token or Firebase.
VITE_GENESIS_API_BEARER_TOKEN=

# Firebase web SDK (production JWT). Optional until auth UI is wired.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=genesis-platform-il.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=genesis-platform-il
